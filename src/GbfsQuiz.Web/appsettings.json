{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "GbfsQuiz",
    "Audience": "GbfsQuiz",
    "ExpiryMinutes": 120
  },
  "Gbfs": {
    "CacheSeconds": 45,
    "Providers": [
      {
        "Id": "citibike-nyc",
        "Name": "Citi Bike",
        "City": "New York City",
        "DiscoveryUrl": "https://gbfs.citibikenyc.com/gbfs/gbfs.json"
      },
      {
        "Id": "bluebikes-bos",
        "Name": "Bluebikes",
        "City": "Boston",
        "DiscoveryUrl": "https://gbfs.bluebikes.com/gbfs/gbfs.json"
      },
      {
        "Id": "divvy-chi",
        "Name": "Divvy",
        "City": "Chicago",
        "DiscoveryUrl": "https://gbfs.divvybikes.com/gbfs/gbfs.json"
      }
    ]
  }
}
